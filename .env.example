NODE_ENV=development

# Database (docker-compose maps Postgres to host port 5433)
DATABASE_URL=postgresql://communication:communication@localhost:5433/communication

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h
API_KEY_SALT=change-me-in-production

# Seed (optional — defaults: admin@sparkco.local + random printed password)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Per-API-key send budget in messages/minute (keys with rate_limit_per_minute set override this)
API_KEY_RATE_LIMIT_PER_MINUTE=60

# CORS origin allowed to call the API (the dashboard)
DASHBOARD_ORIGIN=http://localhost:3000

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# WhatsApp
WHATSAPP_SESSION_PATH=./sessions
WHATSAPP_HEADLESS=true

# Ports
API_PORT=3001
DASHBOARD_PORT=3000
