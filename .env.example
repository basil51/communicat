NODE_ENV=development

# Database
DATABASE_URL=postgresql://communication:communication@localhost:5432/communication

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-in-production
API_KEY_SALT=change-me-in-production

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# WhatsApp
WHATSAPP_SESSION_PATH=./sessions
WHATSAPP_HEADLESS=true

# Ports
API_PORT=3001
DASHBOARD_PORT=3000
