{
  "name": "communication-service",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "argon2",
      "msgpackr-extract",
      "puppeteer",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build:packages": "pnpm --filter './packages/*' build",
    "build": "pnpm build:packages && pnpm --filter './apps/*' build",
    "db:migrate": "pnpm --filter @communication/api db:migrate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
